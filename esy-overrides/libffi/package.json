{
  "name": "esy-libffi",
  "version": "0.0.0",
  "esy": {
    "buildsInSource": true,
    "build": "sh build.sh",
    "exportedEnv": {
      "PKG_CONFIG_PATH": {
        "val": "#{self.install / 'lib' / 'pkgconfig'}",
        "scope": "global"
      },
      "CPATH": {
        "val": "#{self.install / 'include'}",
        "scope": "global"
      },
      "LIBRARY_PATH": {
        "val": "#{self.install / 'lib'}",
        "scope": "global"
      },
      "LD_LIBRARY_PATH": {
        "val": "#{self.install / 'lib'}",
        "scope": "global"
      },
      "DYLD_LIBRARY_PATH": {
        "val": "#{self.install / 'lib'}",
        "scope": "global"
      }
    }
  }
}
