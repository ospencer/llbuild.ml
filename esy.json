{
  "name": "@grain/llbuild.ml",
  "version": "0.1.0",
  "description": "OCaml bindings for llbuild",
  "author": "Oscar Spencer <oscar@grain-lang.org>",
  "license": "Apache-2.0",
  "esy": {
    "build": "dune build -p libllbuild,llbuild -j4",
    "buildsInSource": "_build"
  },
  "scripts": {
    "test": "esy b dune runtest --display=short",
    "format": "dune build @fmt --auto-promote"
  },
  "dependencies": {
    "ocaml": ">=4.14.0",
    "@opam/dune": ">=3.0.0",
    "@opam/dune-configurator": ">=3.0.0",
    "@opam/ctypes": ">=0.21.0",
    "@opam/ctypes-foreign": ">=0.21.0",
    "@opam/conf-cmake": "*"
  },
  "resolutions": {
    "@opam/conf-cmake": "link:./esy-overrides/conf-cmake",
    "@opam/conf-libffi": "link:./esy-overrides/conf-libffi",
    "@opam/conf-pkg-config": "link:./esy-overrides/conf-pkg-config",
    "esy-texinfo": "link:./esy-overrides/texinfo"
  },
  "devDependencies": {
    "@opam/ocaml-lsp-server": "*",
    "@opam/ocamlformat": "0.27.0"
  }
}
